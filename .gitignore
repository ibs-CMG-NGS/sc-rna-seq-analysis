# =============================================================================
# Data directory — 실제 데이터 디렉토리 제외, 루트 구조만 유지
# 새 데이터셋 추가 시 아래 패턴 형식으로 추가
# =============================================================================
data/all-sample/

# =============================================================================
# Output directory — 파이프라인 생성물 제외, 루트 구조만 유지
# Snakemake가 실행 시 자동으로 하위 디렉토리 생성함
# =============================================================================
output/checkpoints/
output/logs/
output/figures/
output/tables/

# =============================================================================
# 생물정보학 대용량 파일 (안전망 — 어디서든 제외)
# =============================================================================
*.h5ad
*.h5
*.loom
*.bam
*.bai
*.cram
*.mtx
*.mtx.gz
*.csv.gz
*.tsv.gz
*.fastq.gz
*.fq.gz
*.fa.gz
*.bigWig
*.bw

# =============================================================================
# Config — 사용자 실제 설정 파일
# configs/*.yaml  → template, 커밋 대상
# configs/_*.yaml → 사용자 실제 설정, gitignore 대상
# 사용법: cp configs/pipeline.yaml configs/_pipeline.yaml → 수정 후 사용
# =============================================================================
configs/_*.yaml
configs/_*.yml

# =============================================================================
# Snakemake
# =============================================================================
.snakemake/
*.snakemake.log

# =============================================================================
# Python
# =============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
dist/
build/
.eggs/

# =============================================================================
# Jupyter
# =============================================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# =============================================================================
# Conda 환경 바이너리 (environment.yml로 재현)
# =============================================================================
.conda/
envs/
env/

# =============================================================================
# Claude Code
# =============================================================================
.claude/

# =============================================================================
# IDE & OS
# =============================================================================
.vscode/
.idea/
*.code-workspace
.DS_Store
Thumbs.db
*Zone.Identifier

# =============================================================================
# 임시 파일
# =============================================================================
*.tmp
*.temp
